# Database
DATABASE_URL="postgres://user:password@host:port/db?ssl=true"

# App
ORIGIN="http://localhost:5173"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Google — used for OAuth login AND Calendar API
# The Calendar refresh token is stored per-user via /admin/settings (Google OAuth flow)
# GOOGLE_CALENDAR_ID is a fallback — each user configures their own via admin settings
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALENDAR_ID="primary"

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Resend
RESEND_API_KEY="re_123456789"
RESEND_FROM_EMAIL="you@yourdomain.com"

# Cron — required; generate with: openssl rand -base64 32
# PUBLIC_APP_URL: use http://app:3000 when running via Docker Compose, otherwise your public domain
PUBLIC_APP_URL="http://localhost:5173"
CRON_SECRET=""

# Set to 'true' to allow public registration
# By default, only the first user can register; others are created by admin
REGISTRATION_OPEN="false"

# Pappers — French company enrichment (optional)
# Get your key at https://www.pappers.fr/api
PAPPERS_API_KEY=""
